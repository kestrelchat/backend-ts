{
  "name": "backend",
  "version": "1.0.0",
  "description": "Core backend service for Kestrel",
  "homepage": "https://github.com/kestrelchat/backend-ts#readme",
  "bugs": {
    "url": "https://github.com/kestrelchat/backend-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kestrelchat/backend-ts.git"
  },
  "license": "AGPL-3.0",
  "author": "kestrel",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "clean": "rimraf dist",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "mocha -r ts-node/register tests/**/*.ts",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "migrate": "py scripts/migrate.py",
    "migrate:new": "npx node-pg-migrate create"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@iarna/toml": "^2.2.5",
    "eslint-plugin-prettier": "^5.5.5",
    "fastify": "^5.8.2",
    "pg": "^8.20.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.4.0",
    "@types/pg": "^8",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-license-header": "^0.9.0",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc": "^2.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.13.0"
}
